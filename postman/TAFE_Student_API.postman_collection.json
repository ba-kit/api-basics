{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
		"name": "TAFE Student Management API v1",
		"description": "Complete API collection for testing the TAFE Student Management System v1.\n\nChange `base_url` variable to switch between local and live:\n- Local: http://localhost:5001\n- Live:  https://tafe-student-api.fly.dev\n\nDemonstrates: GET/POST/PUT/DELETE, nested JSON, pagination, path/query params, error handling.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Health Check",
			"item": [
				{
					"name": "API Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/health",
							"host": ["{{base_url}}"],
							"path": ["api", "health"]
						},
						"description": "Check if the API is running.\n\n**Expected:** 200 OK with status, timestamp, version"
					},
					"response": []
				}
			]
		},
		{
			"name": "Programs",
			"item": [
				{
					"name": "Get All Programs",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json", "type": "text"}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/programs",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "programs"]
						},
						"description": "Returns all programs. Each program has: id, program_code, duration_years.\n\n**Expected:** 200 OK"
					},
					"response": []
				},
				{
					"name": "Get Program by ID",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json", "type": "text"}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/programs/ICT40120",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "programs", "ICT40120"]
						},
						"description": "Get a program by its program_code (the natural primary key).\n\nChange ICT40120 to any code from Get All Programs.\n\n**Expected:** 200 OK or 404 Not Found"
					},
					"response": []
				}
			]
		},
		{
			"name": "Students",
			"item": [
				{
					"name": "Get All Students (Page 1)",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json", "type": "text"}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/students?page=1&per_page=10",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "students"],
							"query": [
								{"key": "page", "value": "1", "description": "Page number"},
								{"key": "per_page", "value": "10", "description": "Items per page"}
							]
						},
						"description": "Paginated list of students. Check `pagination.total` for full count.\n\n**Expected:** 200 OK with data array and pagination object"
					},
					"response": []
				},
				{
					"name": "Get Student Details (Nested JSON)",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json", "type": "text"}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/students/{{student_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "students", "{{student_id}}"]
						},
									"description": "Returns full student with nested program object.\n\nUses `{{student_id}}` variable (default ACT001). The nested program shows program_code as the key.\n\n**Expected:** 200 OK with student + program nested, or 404 Not Found"
					},
					"response": []
				},
				{
					"name": "Create New Student",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json", "type": "text"},
							{"key": "Accept", "value": "application/json", "type": "text"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"email\": \"john.doe@student.tafe.edu.au\",\n  \"enrollment_date\": \"2024-02-26\",\n  \"program_code\": \"ICT40120\"\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{base_url}}/api/v1/students",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "students"]
						},
						"description": "Create a new student. ID is auto-generated (ACT021, ACT022...).\n\nAfter running, `{{student_id}}` is auto-set from the response — Update and Delete will use it automatically.\n\n**Required fields:** first_name, last_name, email, program_code\n**Optional:** enrollment_date (defaults to today)\n\n**Expected:** 201 Created | 400 Bad Request | 409 Conflict (duplicate email)"
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"if (json.data && json.data.id) {",
									"    pm.collectionVariables.set('student_id', json.data.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"response": []
				},
				{
					"name": "Update Student",
					"request": {
						"method": "PUT",
						"header": [
							{"key": "Content-Type", "value": "application/json", "type": "text"},
							{"key": "Accept", "value": "application/json", "type": "text"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"first_name\": \"John\",\n  \"last_name\": \"Smith\",\n  \"email\": \"john.smith@student.tafe.edu.au\",\n  \"program_code\": \"ICT50220\"\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{base_url}}/api/v1/students/{{student_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "students", "{{student_id}}"]
						},
						"description": "Update an existing student. Uses `{{student_id}}` — run Create first to auto-set it, or set manually.\n\nAll fields optional — only provided fields updated.\n\n**Expected:** 200 OK | 404 Not Found | 409 Conflict"
					},
					"response": []
				},
				{
					"name": "Delete Student",
					"request": {
						"method": "DELETE",
						"header": [
							{"key": "Accept", "value": "application/json", "type": "text"}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/students/{{student_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "students", "{{student_id}}"]
						},
						"description": "Delete a student by ID. Uses `{{student_id}}` — run Create first to auto-set it, or set manually.\n\n**Expected:** 200 OK | 404 Not Found"
					},
					"response": []
				}
			]
		},
		{
			"name": "Error Examples",
			"item": [
				{
					"name": "404 - Student Not Found",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/students/ACT999",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "students", "ACT999"]
						},
						"description": "Requesting a non-existent student ID.\n\n**Expected:** 404 Not Found with error message"
					},
					"response": []
				},
				{
					"name": "400 - Missing Required Fields",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json", "type": "text"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"first_name\": \"Test\"\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{base_url}}/api/v1/students",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "students"]
						},
						"description": "POST with only first_name — missing last_name, email, program_id.\n\n**Expected:** 400 Bad Request with validation error details"
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:5001",
			"type": "string",
			"description": "Switch to https://tafe-student-api.fly.dev for live API"
		},
		{
			"key": "student_id",
			"value": "ACT001",
			"type": "string",
			"description": "Auto-set after Create New Student. Change manually to target a specific student."
		}
	]
}
